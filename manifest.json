{
  "manifest_version": 3,
  "name": "aQuerium",
  "version": "1.0",
  "description": "Query-osity killed the fish!",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fish/goldfish.png","fish/pufferfish.png"],
      "matches": ["<all_urls>"]
    }
  ]
}