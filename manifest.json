{
  "manifest_version": 3,
  "name": "aQuerium",
  "version": "1.0",
  "description": "Query-osity killed the fish!",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fish/goldfish.png","fish/pufferfish.png","fish/shark.png","fish/lemonshark.png",
    "fish/tuna.png","fish/bettafish.png","fish/lionfish.png","fish/dead_goldfish.png","fish/dead_pufferfish.png",
    "fish/dead_shark.png","fish/dead_lemonshark.png","fish/dead_tuna.png","fish/dead_bettafish.png","fish/dead_lionfish.png"],
      "matches": ["<all_urls>"]
    }
  ]
}